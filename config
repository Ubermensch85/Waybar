{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 5,
    "margin-top": 3,
    "margin-left": 3,
    "margin-right": 3,

    "modules-left": ["custom/arch", "custom/updates", "disk", "cpu", "memory", "custom/weather"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["temperature", "custom/gammastep", "backlight", "pulseaudio", "battery", "network", "tray", "clock"],

   "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
        "1": "<span font='DejaVu Serif 11'>Ⅰ</span>",
        "2": "<span font='DejaVu Serif 11'>Ⅱ</span>",
        "3": "<span font='DejaVu Serif 11'>Ⅲ</span>",
        "4": "<span font='DejaVu Serif 11'>Ⅳ</span>",
        "5": "<span font='DejaVu Serif 11'>Ⅴ</span>",
        "6": "<span font='DejaVu Serif 11'>Ⅵ</span>",
        "7": "<span font='DejaVu Serif 11'>Ⅶ</span>",
        "8": "<span font='DejaVu Serif 11'>Ⅷ</span>",
        "9": "<span font='DejaVu Serif 11'>Ⅸ</span>",
        "10": "<span font='DejaVu Serif 11'>Ⅹ</span>"
    }
},

    "custom/arch": {
    "format": " <span size='x-large'>󰣇</span> ",
        "tooltip": false,
        "on-click": "python3 ~/.config/waybar/scripts/show_arch_info.py"
    },

"tray": {
    "ignore": ["innu", "Innu"]
},


    "custom/updates": {
    "format": "{}",
    "interval": 60,
    "exec": "/usr/local/bin/check-updates.sh",
    "exec-if": "exit 0",
    "on-click": "alacritty -e bash -c '~/update.sh; read -p \"Premi Enter per chiudere...\"'",
    "on-click-right": "pkill -RTMIN+8 waybar",
    "signal": 8
},

    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 3600,
        "exec": "~/.config/waybar/scripts/weather.sh",
        "return-type": "json"
    },

    "custom/gammastep": {
        "exec": "~/.config/waybar/scripts/gammastep_status.sh",
        "return-type": "json",
        "interval": 5
    },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "{:%d-%m-%Y}",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#4d97ff'><b>{}</b></span>",
                "today": "<span color='#ff6384'><b><u>{}</u></b></span>"
            }
        }
    },

    "network": {
        "format-wifi": "󰤨 ",
        "format-ethernet": "󰈀 ",
        "format-disconnected": "󰤮 ",
		"tooltip-format-wifi": "WiFi: {essid}\nSegnale: {signalStrength}%\nIP: {ipaddr}",
    "tooltip-format-ethernet": "Ethernet\nIP: {ipaddr}",
    "tooltip-format-disconnected": "Nessuna connessione",
	"on-click": "networkmanager_dmenu"
    },


    "cpu": { "format": "  {usage}%" },
    "memory": { "format": "󰘚  {percentage}%" },
    "disk": { "format": "󰋊  {percentage_used}%" },
    "temperature": { "format": "  {temperatureC}°C" },
    
    "backlight": {
        "format": "{icon}   {percent}%",
        "tooltip-format": "{percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"] 
    },    
    
    "battery": {
    "states": {
        "warning": 18,
        "critical": 5
    },
    "format": "{icon}    {capacity}%",
    "format-charging": "    {capacity}%",
    "format-plugged": "   {capacity}%",
    "format-icons": ["", "", "", "", ""],
    "tooltip-format": "{power}W "
},

    "battery#bat2": {
        "bat": "BAT2"
    },

    "pulseaudio#mic": {
        "scroll-step": 10,
        "format": "{format_source}",
        "format-bluetooth": "{icon}",
        "format-muted": "<span font='Font Awesome 7 Free'></span> ", 
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "tooltip-format": "{volume}%"
    },

    "pulseaudio": {
        "scroll-step": 10,
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}",
        "format-muted": "󰝟 ",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{volume}%"
    }
}
